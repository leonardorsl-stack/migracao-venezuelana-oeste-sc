# =============================================================================
# TEMPLATE DE VARIÁVEIS DE AMBIENTE
# =============================================================================
# INSTRUÇÕES:
#   1. Copie este arquivo para .env:  cp .env.example .env
#   2. Preencha os valores abaixo com suas credenciais.
#   3. NUNCA versione o arquivo .env (já está no .gitignore).
#   4. NUNCA compartilhe tokens ou chaves em repositórios públicos.
# =============================================================================

# -----------------------------------------------------------------------------
# Zenodo (arquivamento e DOI)
# Documentação: https://developers.zenodo.org/
# -----------------------------------------------------------------------------
ZENODO_TOKEN=""

# -----------------------------------------------------------------------------
# OSF (Open Science Framework)
# Documentação: https://developer.osf.io/
# -----------------------------------------------------------------------------
OSF_TOKEN=""
OSF_NODE_ID=""

# -----------------------------------------------------------------------------
# Zotero (gestão bibliográfica)
# Documentação: https://www.zotero.org/support/dev/web_api/v3/start
# -----------------------------------------------------------------------------
ZOTERO_API_KEY=""
ZOTERO_USER_ID=""
ZOTERO_GROUP_ID=""

# -----------------------------------------------------------------------------
# Caminhos de dados (opcional; se vazio, usa os padrões do projeto)
# -----------------------------------------------------------------------------
RAW_DATA_PATH=""
PROCESSED_DATA_PATH=""
INTERIM_DATA_PATH=""
EXTERNAL_DATA_PATH=""

# -----------------------------------------------------------------------------
# DataSUS / PySUS (opcional)
# -----------------------------------------------------------------------------
DATASUS_USER=""
DATASUS_PASSWORD=""

# -----------------------------------------------------------------------------
# IBGE / SIDRA (opcional)
# -----------------------------------------------------------------------------
IBGE_API_KEY=""

# -----------------------------------------------------------------------------
# Configurações de execução
# -----------------------------------------------------------------------------
PYTHONDONTWRITEBYTECODE="1"
PYTHONUNBUFFERED="1"
